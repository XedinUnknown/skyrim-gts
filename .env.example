# Copy to .env for local use. Do not commit .env.

# Optional. Required only for `make mod-metadata-enrich` to fetch Nexus API details.
NEXUS_API_KEY=

# Host paths used by Docker Compose volume mounts.
GTS_HOST_PATH=/mnt/e/games/GTSAV
MOD_METADATA_CACHE_HOST_DIR=/home/owner/.cache/skyrim-gts

# Runtime paths for host-side Make. Docker Compose overrides GTS_PATH to /gts.
GTS_PATH=/mnt/e/games/GTSAV
GTS_PROFILE_PATH=/mnt/e/games/GTSAV/profiles/Gate to Sovngarde Anniversary Edition Upgrade
GTS_DB=cache/gts-index/gts.sqlite
GTS_RECIPE_INDEX_DIR=cache/gts-item-recipe-index
GTS_MOD_METADATA_DIR=cache/gts-mod-metadata-index
GTS_MOD_METADATA_CACHE_DB=/home/owner/.cache/skyrim-gts/mod-metadata-cache.sqlite

# Host install defaults to /mnt/e/games/util/dotnet/dotnet.
# Docker Compose sets this to /usr/bin/dotnet.
DOTNET=/mnt/e/games/util/dotnet/dotnet
