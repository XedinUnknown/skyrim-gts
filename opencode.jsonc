{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "skyrim": {
      "type": "remote",
      "url": "http://127.0.0.1:8765/mcp",
      "timeout": 30000
    }
  },
  "provider": {
    "ollama": {
      "api": "openai",
      "options": {
        "baseURL": "http://host.docker.internal:11434/v1",
        "apiKey": "ollama"
      },
      "models": {
        "qwen3-coder:latest": {
          "id": "qwen3-coder:latest",
          "name": "Qwen3 Coder",
          "family": "qwen3"
        }
      }
    }
  }
}
